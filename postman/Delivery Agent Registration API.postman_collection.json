              "mode": "raw",
              "raw": "{\r\n    \"email\": \"test@example.com\",\r\n    \"type\": \"login\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/v1/send-otp?lang={{lang}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "send-otp"
              ],
              "query": [
