    {
      "name": "Task Management (إدارة المهام)",
      "item": [
        {
          "name": "1. Get Available Tasks",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/delivery-agent/tasks/available?type={{type}}&lang={{lang}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "delivery-agent", "tasks", "available"],
              "query": [
                { "key": "type", "value": "{{type}}" },
                { "key": "lang", "value": "{{lang}}" }
              ]
            },
            "description": "جلب المهام المتاحة للقريبين بناءً على نوع خدمة المندوب"
          }
        },
        {
          "name": "2. Accept Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/delivery-agent/tasks/:type/:id/accept?lang={{lang}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "delivery-agent", "tasks", ":type", ":id", "accept"],
              "query": [{ "key": "lang", "value": "{{lang}}" }],
              "variable": [
                { "key": "type", "value": "order", "description": "order, delivery, car_wash" },
                { "key": "id", "value": "1" }
              ]
            },
            "description": "قبول مهمة معينة (استبدل :type بـ order أو delivery أو car_wash حسب نوع المهمة)"
          }
        },
        {
          "name": "3. Get Active Tasks",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/delivery-agent/tasks/active?status=in_progress&lang={{lang}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "delivery-agent", "tasks", "active"],
              "query": [
                { "key": "status", "value": "in_progress" },
                { "key": "lang", "value": "{{lang}}" }
              ]
            },
            "description": "عرض مهامي الحالية أو المكتملة"
          }
        },
        {
          "name": "4. Upload Task Proof (Photos)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "item_photo", "type": "file", "value": null },
                { "key": "invoice_photo", "type": "file", "value": null }
              ]
            },
            "url": {
              "raw": "{{base_url}}/v1/delivery-agent/tasks/:type/:id/proof?lang={{lang}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "delivery-agent", "tasks", ":type", ":id", "proof"],
              "query": [{ "key": "lang", "value": "{{lang}}" }],
              "variable": [
                { "key": "type", "value": "order" },
                { "key": "id", "value": "1" }
              ]
            },
            "description": "رفع صور الفاتورة أو الغرض لإثبات العملية"
          }
        },
        {
          "name": "5. Update Task Status (Complete)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"completed\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/v1/delivery-agent/tasks/:type/:id/status?lang={{lang}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "delivery-agent", "tasks", ":type", ":id", "status"],
              "query": [{ "key": "lang", "value": "{{lang}}" }],
              "variable": [
                { "key": "type", "value": "order" },
                { "key": "id", "value": "1" }
              ]
            },
            "description": "تحديث حالة المهمة إلى مكتملة أو ملغاة"
          }
        }
      ]
    }
  ],
