{
  "info": {
    "_postman_id": "1742d733-4663-436b-b29f-c8dc15d8c7f5",
    "name": "Delivery Agent Registration API",
    "description": "API endpoints for delivery agent registration system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "50657319",
