{
    "info": {
        "_postman_id": "delivery-agent-registration",
        "name": "Delivery Agent Registration API",
        "description": "API endpoints for delivery agent registration system",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Delivery Registration",
            "item": [
                {
                    "name": "1. Send OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"test@example.com\",\n    \"type\": \"registration\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/send-otp?lang={{lang}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "send-otp"
                            ],
                            "query": [
                                {
                                    "key": "lang",
                                    "value": "{{lang}}"
                                }
                            ]
                        },
                        "description": "إرسال رمز التحقق OTP إلى البريد الإلكتروني للبدء في عملية التسجيل"
                    },
                    "response": []
                },
                {
                    "name": "2. Verify OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"test@example.com\",\n    \"code\": \"{{otp}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/verify-otp?lang={{lang}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "verify-otp"
                            ],
                            "query": [
                                {
                                    "key": "lang",
                                    "value": "{{lang}}"
                                }
                            ]
                        },
                        "description": "التحقق من رمز OTP والحصولة على الـ temp_token"
                    },
                    "response": []
                },
                {
                    "name": "3. Personal Details (Step 1)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "temp_token",
                                    "value": "{{temp_token}}",
                                    "type": "text",
                                    "description": "توكن التحقق المؤقت"
                                },
                                {
                                    "key": "name",
                                    "value": "أحمد محمد",
                                    "type": "text",
                                    "description": "اسم عامل التوصيل بالكامل"
                                },
                                {
                                    "key": "phone",
                                    "value": "0501234567",
                                    "type": "text",
                                    "description": "رقم الجوال (يجب أن يكون فريداً)"
                                },
                                {
                                    "key": "nationality",
                                    "value": "السعودية",
                                    "type": "text",
                                    "description": "الجنسية"
                                },
                                {
                                    "key": "national_id_number",
                                    "value": "1234567890",
                                    "type": "text",
                                    "description": "رقم الهوية أو الإقامة"
                                },
                                {
                                    "key": "birth_date",
                                    "value": "1995-05-15",
                                    "type": "text",
                                    "description": "تاريخ الميلاد (YYYY-MM-DD)"
                                },
                                {
                                    "key": "profile_photo",
                                    "type": "file",
                                    "src": [],
                                    "description": "الصورة الشخصية"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/delivery-agent/complete-profile?lang={{lang}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "delivery-agent",
                                "complete-profile"
                            ],
                            "query": [
                                {
                                    "key": "lang",
                                    "value": "{{lang}}"
                                }
                            ]
                        },
                        "description": "الخطوة الأولى: إدخال البيانات الشخصية ورفع الصورة الشخصية"
                    },
                    "response": []
                },
                {
                    "name": "4. Vehicle Details & Documents (Step 2)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "temp_token",
                                    "value": "{{temp_token}}",
                                    "type": "text",
                                    "description": "توكن التحقق"
                                },
                                {
                                    "key": "vehicle_type",
                                    "value": "car",
                                    "type": "text",
                                    "description": "نوع المركبة (car, motorcycle, etc)"
                                },
                                {
                                    "key": "vehicle_brand",
                                    "value": "Toyota",
                                    "type": "text",
                                    "description": "ماركة المركبة"
                                },
                                {
                                    "key": "vehicle_model",
                                    "value": "Camry",
                                    "type": "text",
                                    "description": "موديل المركبة"
                                },
                                {
                                    "key": "manufacturing_year",
                                    "value": "2022",
                                    "type": "text",
                                    "description": "سنة التصنيع"
                                },
                                {
                                    "key": "license_plate_number",
                                    "value": "1234",
                                    "type": "text",
                                    "description": "أرقام اللوحة"
                                },
                                {
                                    "key": "license_plate_letters",
                                    "value": "أ ب ج",
                                    "type": "text",
                                    "description": "حروف اللوحة"
                                },
                                {
                                    "key": "license_type",
                                    "value": "Private",
                                    "type": "text",
                                    "description": "نوع الرخصة"
                                },
                                {
                                    "key": "id_front",
                                    "type": "file",
                                    "src": [],
                                    "description": "صورة الهوية من الأمام"
                                },
                                {
                                    "key": "id_back",
                                    "type": "file",
                                    "src": [],
                                    "description": "صورة الهوية من الخلف"
                                },
                                {
                                    "key": "driving_license",
                                    "type": "file",
                                    "src": [],
                                    "description": "صورة رخصة القيادة"
                                },
                                {
                                    "key": "vehicle_registration_front",
                                    "type": "file",
                                    "src": [],
                                    "description": "صورة الاستمارة من الأمام"
                                },
                                {
                                    "key": "vehicle_registration_back",
                                    "type": "file",
                                    "src": [],
                                    "description": "صورة الاستمارة من الخلف"
                                },
                                {
                                    "key": "criminal_record",
                                    "type": "file",
                                    "src": [],
                                    "description": "صحيفة الحالة الجنائية"
                                },
                                {
                                    "key": "medical_check",
                                    "type": "file",
                                    "src": [],
                                    "description": "الفحص الطبي أو شهادة اللياقة (خاص بالعجلة)"
                                },
                                {
                                    "key": "vehicle_insurance",
                                    "type": "file",
                                    "src": [],
                                    "description": "تأمين المركبة"
                                },
                                {
                                    "key": "vehicle_photo",
                                    "type": "file",
                                    "src": [],
                                    "description": "صورة المركبة بالكامل"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/delivery-agent/register-vehicle?lang={{lang}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "delivery-agent",
                                "register-vehicle"
                            ],
                            "query": [
                                {
                                    "key": "lang",
                                    "value": "{{lang}}"
                                }
                            ]
                        },
                        "description": "الخطوة الثانية: بيانات المركبة ورفع كافة المستندات المطلوبة في طلب واحد"
                    },
                    "response": []
                },
                {
                    "name": "5. Bank Details (LAST STEP - FINALIZE)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"temp_token\": \"{{temp_token}}\",\n    \"bank_name\": \"البنك الأهلي السعودي\",\n    \"account_holder_name\": \"أحمد محمد علي\",\n    \"iban\": \"SA1234567890123456789012\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/delivery-agent/register-bank?lang={{lang}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "delivery-agent",
                                "register-bank"
                            ],
                            "query": [
                                {
                                    "key": "lang",
                                    "value": "{{lang}}"
                                }
                            ]
                        },
                        "description": "الخطوة الثالثة والأخيرة: إدخال البيانات البنكية، وعند الإرسال يتم إنشاء الحساب رسمياً واستلام التوكن"
                    },
                    "response": []
                },
                {
                    "name": "Registration Status (Bearer Token Required)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/v1/delivery-agent/registration-status?lang={{lang}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "delivery-agent",
                                "registration-status"
                            ],
                            "query": [
                                {
                                    "key": "lang",
                                    "value": "{{lang}}"
                                }
                            ]
                        },
                        "description": "التحقق من حالة الحساب بعد التسجيل (يتطلب التوكن النهائي)"
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://127.0.0.1:8000/api",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        },
        {
            "key": "temp_token",
            "value": "",
            "type": "string"
        },
        {
            "key": "otp",
            "value": "",
            "type": "string"
        },
        {
            "key": "lang",
            "value": "ar",
            "type": "string"
        }
    ]
}